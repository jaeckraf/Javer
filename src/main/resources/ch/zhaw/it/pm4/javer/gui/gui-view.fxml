<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="ch.zhaw.it.pm4.javer.gui.GuiController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <TextArea fx:id="consoleInput" promptText="Type command here..." prefHeight="300" prefWidth="550"/>
    <Button fx:id="runCompilerButton" text="Run Compiler" onAction="#onRunCompilerClick"/>
    <TextArea fx:id="compilerOutput" editable="false" prefHeight="300" prefWidth="550" wrapText="true"/>
    <TextArea fx:id="virtualMachineOutput" editable="false" prefHeight="300" prefWidth="550" wrapText="true"/>

</VBox>
